{
  "name": "kavion",
  "version": "0.2.3",
  "description": "Structured AI software team workflows with local project memory, real workflow gates, and durable session state.",
  "contextFileName": "KAVION.md",
  "mcpServers": {
    "kavion-worker": {
      "command": "node",
      "args": [
        "${extensionPath}${/}mcp-server${/}launch.js"
      ],
      "cwd": "${workspacePath}",
      "env": {
        "KAVION_WORKSPACE_PATH": "${workspacePath}"
      }
    }
  }
}
